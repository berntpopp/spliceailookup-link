# spliceailookup-link configuration (all vars prefixed SPLICEAILOOKUP_LINK_ are optional)

# Upstream scoring API hosts. {hg} is replaced with 37 or 38.
# Defaults are the official Broad Cloud Run hosts documented in the
# SpliceAI-lookup README.
SPLICEAILOOKUP_LINK_SPLICEAI_URL_TEMPLATE=https://spliceai-{hg}-xwkwwwxdwq-uc.a.run.app/spliceai/
SPLICEAILOOKUP_LINK_PANGOLIN_URL_TEMPLATE=https://pangolin-{hg}-xwkwwwxdwq-uc.a.run.app/pangolin/

# Ensembl VEP REST hosts used to resolve HGVS / rsIDs into chrom-pos-ref-alt.
SPLICEAILOOKUP_LINK_ENSEMBL_GRCH38_URL=https://rest.ensembl.org
SPLICEAILOOKUP_LINK_ENSEMBL_GRCH37_URL=https://grch37.rest.ensembl.org

# Request handling. The upstream is "interactive use only, several requests
# per user per minute" and individual calls can take 30s+, so be conservative.
SPLICEAILOOKUP_LINK_REQUEST_TIMEOUT=90
SPLICEAILOOKUP_LINK_MAX_CONCURRENCY=2
SPLICEAILOOKUP_LINK_QUEUE_WAIT_TIMEOUT=30

# Proactive client-pacing signal surfaced as _meta.rate_budget.min_interval_ms:
# the recommended soft spacing (ms) between cache-miss scoring calls.
SPLICEAILOOKUP_LINK_RATE_BUDGET_MIN_INTERVAL_MS=12000

# In-process cache (scoring is deterministic per variant+params, so cache hard).
SPLICEAILOOKUP_LINK_CACHE_SIZE=1024
SPLICEAILOOKUP_LINK_CACHE_TTL_MINUTES=1440

# Transport
SPLICEAILOOKUP_LINK_MCP_TRANSPORT=unified
SPLICEAILOOKUP_LINK_MCP_HOST=127.0.0.1
SPLICEAILOOKUP_LINK_MCP_PORT=8603
SPLICEAILOOKUP_LINK_MCP_PATH=/mcp

# Logging
SPLICEAILOOKUP_LINK_LOG_LEVEL=INFO
SPLICEAILOOKUP_LINK_STDIO_LOG_LEVEL=WARNING

# CORS
SPLICEAILOOKUP_LINK_CORS_ORIGINS=*
